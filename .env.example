# SPARTAN v2.0 — Environment Configuration
# Copy this file to .env and fill in your API keys

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Choose one: openai | anthropic | openrouter | gemini
SPARTAN_LLM_PROVIDER=openai

# ── API Keys (set the one matching your provider) ─────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=sk-or-...
GEMINI_API_KEY=AIza...

# ── Model selection ───────────────────────────────────────────────────────────
# OpenAI models:    gpt-4o | gpt-4o-mini | gpt-4-turbo
SPARTAN_LLM_MODEL=gpt-4o

# Anthropic models: claude-opus-4-5 | claude-sonnet-4-5 | claude-haiku-3-5
SPARTAN_ANTHROPIC_MODEL=claude-opus-4-5

# OpenRouter model: any model from https://openrouter.ai/models
SPARTAN_OPENROUTER_MODEL=anthropic/claude-opus-4-5

# Gemini models: gemini-2.0-flash | gemini-2.0-flash-lite | gemini-2.5-pro-preview-03-25
SPARTAN_GEMINI_MODEL=gemini-2.0-flash

# ── Generation parameters ─────────────────────────────────────────────────────
SPARTAN_MAX_TOKENS=8192
SPARTAN_TEMPERATURE=0.2

# ── Behaviour flags ───────────────────────────────────────────────────────────
SPARTAN_STREAM=true             # Stream tokens to terminal in real-time
SPARTAN_SAVE_SESSIONS=true      # Auto-save session state to disk
SPARTAN_AUTO_ADVANCE=true       # Suggest phase advancement automatically
